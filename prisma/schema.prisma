generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Dog {
  id               String    @id @default(cuid())
  registrySystem   String?
  nickname         String?
  name             String
  registrationName String?
  breed            String
  variety          String?
  birthDate        DateTime?
  color            String
  arrivalDate      DateTime?
  height           Float?
  nationality      String?
  sex              String
  temperament      String?
  status           String    @default("ATIVO")
  showGenealogy    Boolean   @default(true)
  notes            String?
  coat             String?
  profilePhoto     String?
  media            String?
  videos           String?
  microchip        String?
  microchipDate    DateTime?
  dnaProfile       String?
  tagId            String?
  tattoo           String?
  coi              String?
  hipDysplasia     String?
  elbowDysplasia   String?
  patellaLuxation  String?
  healthDocsUrls   String?
  pedigreeId       String?
  pedigreeDocUrl   String?
  sireId           String?
  damId            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  dam              Dog?      @relation("PedigreeDam", fields: [damId], references: [id])
  damOffspring     Dog[]     @relation("PedigreeDam")
  sire             Dog?      @relation("PedigreeSire", fields: [sireId], references: [id])
  sireOffspring    Dog[]     @relation("PedigreeSire")
  damLitters       Litter[]  @relation("DamLitters")
  sireLitters      Litter[]  @relation("SireLitters")
  vaccines         Vaccine[]
}

model Litter {
  id                String    @id @default(cuid())
  title             String?
  matingDate        DateTime?
  expectedBirthDate DateTime?
  birthDate         DateTime?
  status            String    @default("PLANEJADA")
  price             Float?
  sireId            String?
  damId             String?
  media             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  dam               Dog?      @relation("DamLitters", fields: [damId], references: [id])
  sire              Dog?      @relation("SireLitters", fields: [sireId], references: [id])
  puppies           Puppy[]
}

model Puppy {
  id          String    @id @default(cuid())
  name        String?
  sex         String
  color       String
  coat        String?
  birthWeight Float?
  price       Float?
  status      String    @default("DISPONIVEL")
  photo       String?
  buyerId     String?
  saleDate    DateTime?
  litterId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  buyer       Client?   @relation(fields: [buyerId], references: [id])
  litter      Litter    @relation(fields: [litterId], references: [id])
  vaccines    Vaccine[]
}

model Vaccine {
  id          String    @id @default(cuid())
  name        String
  dueDate     DateTime
  appliedDate DateTime?
  status      String    @default("PENDENTE")
  notes       String?
  dogId       String?
  puppyId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  dog         Dog?      @relation(fields: [dogId], references: [id])
  puppy       Puppy?    @relation(fields: [puppyId], references: [id])
}

model Client {
  id            String        @id @default(cuid())
  name          String
  cpf           String?
  email         String?
  phone         String
  address       String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  puppiesBought Puppy[]
  transactions  Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  description String
  amount      Float
  date        DateTime
  clientId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client?  @relation(fields: [clientId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  interest  String
  status    String   @default("NOVO")
  answers   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  type      String   @default("text")
  updatedAt DateTime @updatedAt
}
